{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/dongquoctien/claude-code-plugins/main/plugins/angular-admin-design/schemas/plan.schema.json",
  "title": "angular-admin-design feature plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "feature", "domain", "createdAt", "spec", "scope", "screens", "models", "endpoints", "state", "i18n"],
  "properties": {
    "version": { "const": 1 },
    "feature": { "type": "string", "description": "kebab-case feature name (matches folder under routes/)" },
    "domain": { "type": "string", "description": "Domain prefix without the trailing dash (e.g. 'bs', 'ho', 'fl')" },
    "scope": {
      "type": "string",
      "description": "For subtree projects like partners: 'seller' | 'vendor' | null. For oh-admin: null.",
      "nullable": true
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["local-file", "jira"],
          "description": "Where the spec came from."
        },
        "sourcePath": { "type": "string", "description": "For local-file: absolute path to the spec.md." },
        "jiraKey": { "type": "string", "description": "For jira: 'OHM-1234'." },
        "jiraSummary": { "type": "string" },
        "jiraStatus": { "type": "string" },
        "attachments": {
          "type": "array",
          "description": "Extra files referenced or attached (paths relative to projectRoot).",
          "items": { "type": "string" }
        },
        "title": { "type": "string", "description": "Human-readable title of the feature." },
        "prototypes": {
          "type": "array",
          "description": "(v0.5.0) UI prototypes referenced in the spec — detected by scripts/detect-prototype.mjs. Skill optionally invokes Chrome MCP to snapshot each one, saves to .spec/prototype-snapshots/.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "source", "confidence", "status"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["github-io", "static-host", "sandbox", "live-url", "local-html", "local-react", "local-file"],
                "description": "github-io / static-host (netlify/vercel/etc) / sandbox (codesandbox/stackblitz) / live-url (other hosts) / local-html / local-react (.tsx/.jsx) / local-file"
              },
              "source": {
                "type": "string",
                "description": "URL or absolute/relative path."
              },
              "confidence": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "status": {
                "type": "string",
                "enum": ["detected", "user-confirmed", "user-skipped", "inspected", "inspection-failed"],
                "description": "Lifecycle: detected → user-confirmed → inspected. Or detected → user-skipped. Or detected → inspection-failed (MCP error, URL unreachable, etc)."
              },
              "contextLine": {
                "type": "string",
                "description": "The line in the spec where the prototype reference was found (for human review)."
              },
              "lineNumber": { "type": "integer" },
              "sourceFile": {
                "type": "string",
                "description": "Spec file (relative to projectRoot) the reference was found in."
              },
              "hostHint": { "type": ["string", "null"] },
              "inspectedAt": { "type": "string", "format": "date-time" },
              "snapshotPath": {
                "type": "string",
                "description": "Path (relative to planDir) where the Chrome MCP accessibility-tree snapshot was saved. NOTE: take_snapshot output is plain-text (.txt), not JSON — file ends .txt."
              },
              "screenshotPath": {
                "type": "string",
                "description": "Path (relative to planDir) where the screenshot PNG was saved."
              },
              "sourceFindingsPath": {
                "type": "string",
                "description": "(v0.8.0) Path (relative to planDir) to parse-prototype-source.mjs JSON output. Set when prototype is local .tsx/.jsx/.html and source was statically parsed."
              },
              "textFindingsPath": {
                "type": "string",
                "description": "(v1.0.0) Path (relative to planDir) to extract-prototype-text.mjs JSON output with textStrings[] (i18n key suggestions) + colorHints[]."
              },
              "secondarySnapshots": {
                "type": "array",
                "description": "Additional snapshots captured by walking the prototype (e.g. after clicking entry-point button to reveal drawer/modal). Each is { label, snapshotPath, screenshotPath }.",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["label", "snapshotPath"],
                  "properties": {
                    "label": { "type": "string", "description": "What this captures, e.g. 'drawer', 'tab-Booking', 'modal-history'." },
                    "snapshotPath": { "type": "string" },
                    "screenshotPath": { "type": "string" },
                    "route": { "type": "string", "description": "(v0.7.0) Route slug this snapshot was taken in. Omitted for single-screen prototypes." }
                  }
                }
              },
              "routes": {
                "type": "array",
                "description": "(v0.7.0) Sibling routes detected via detect-prototype-routes.mjs. Each represents a separate screen the prototype navigates to.",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["kind", "url", "slug"],
                  "properties": {
                    "kind": {
                      "type": "string",
                      "enum": ["hash", "path", "nav-link"]
                    },
                    "url": { "type": "string" },
                    "slug": { "type": "string", "description": "Last meaningful URL segment used as filename suffix" },
                    "label": { "type": "string" },
                    "location": {
                      "type": "string",
                      "enum": ["main", "dialog", "banner", "sidebar", "other"]
                    },
                    "score": { "type": "number", "minimum": 0, "maximum": 1 },
                    "walked": { "type": "boolean", "description": "Whether the skill walked this route + captured snapshots" },
                    "snapshotPath": { "type": "string", "description": "Initial snapshot for this route (if walked)" },
                    "screenshotPath": { "type": "string" }
                  }
                }
              },
              "routeMap": {
                "type": "object",
                "description": "(v0.7.0) Map of route slug → plan.screens[i].id. Populated by spec-analyzer after deciding which prototype route maps to which planned screen.",
                "additionalProperties": { "type": "string" }
              },
              "inspectionError": {
                "type": "string",
                "description": "Populated when status=inspection-failed."
              },
              "note": { "type": "string" }
            }
          }
        }
      }
    },
    "summary": { "type": "string", "description": "2-3 sentence narrative summary in workingLanguage." },
    "userStories": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string", "description": "ac-NN" },
          "text": { "type": "string" }
        }
      }
    },
    "businessRules": {
      "type": "array",
      "description": "Domain rules extracted from spec + claude-context/business-rules.md.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "sourceFile": { "type": "string", "description": "Where this rule was sourced from." }
        }
      }
    },
    "screens": {
      "type": "array",
      "description": "Each screen becomes one container component.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "kind"],
        "properties": {
          "id": { "type": "string", "description": "kebab-case screen id" },
          "title": { "type": "string", "description": "Display title in workingLanguage" },
          "kind": {
            "type": "string",
            "enum": ["list", "form", "detail", "wizard", "dashboard", "report", "custom"]
          },
          "containerClassName": {
            "type": "string",
            "description": "Suggested smart-component class name, e.g. BookingCancelComponent"
          },
          "route": { "type": "string", "description": "Route path under the feature module, e.g. '' or 'detail/:id'" },
          "sections": {
            "type": "array",
            "description": "Logical UI sections for the screen (search, results grid, edit form, etc.)",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "purpose"],
              "properties": {
                "id": { "type": "string" },
                "purpose": { "type": "string" },
                "fields": {
                  "type": "array",
                  "description": "Form fields if applicable.",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["name", "type"],
                    "properties": {
                      "name": { "type": "string" },
                      "label": { "type": "string" },
                      "type": {
                        "type": "string",
                        "enum": ["text", "number", "email", "password", "select", "multiselect", "checkbox", "radio", "date", "daterange", "datetime", "textarea", "file", "autocomplete", "custom"]
                      },
                      "required": { "type": "boolean" },
                      "options": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": ["label", "value"],
                          "properties": {
                            "label": { "type": "string" },
                            "value": {}
                          }
                        }
                      },
                      "validation": {
                        "type": "object",
                        "additionalProperties": true,
                        "description": "Free-form: { pattern, min, max, custom: 'sameAs:passwordConfirm', ... }"
                      },
                      "default": {}
                    }
                  }
                },
                "columns": {
                  "type": "array",
                  "description": "Grid columns if section.purpose mentions a grid.",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["field", "title"],
                    "properties": {
                      "field": { "type": "string" },
                      "title": { "type": "string" },
                      "type": { "type": "string", "description": "string | number | date | code | custom" },
                      "width": { "type": "string" },
                      "sortable": { "type": "boolean" },
                      "filterable": { "type": "boolean" }
                    }
                  }
                },
                "actions": {
                  "type": "array",
                  "description": "Buttons / CTAs in this section.",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["id", "label", "kind"],
                    "properties": {
                      "id": { "type": "string" },
                      "label": { "type": "string" },
                      "kind": { "type": "string", "enum": ["primary", "secondary", "danger", "link", "icon"] },
                      "dispatches": { "type": "string", "description": "NgRx action it dispatches (camelCase, suggested by planner)." }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "models": {
      "type": "array",
      "description": "Interfaces this feature needs. If `existingInterface` is set, plugin will reuse instead of creating new.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "purpose"],
        "properties": {
          "name": { "type": "string", "description": "Interface name with I-prefix, e.g. IBookingCancelRequest" },
          "purpose": { "type": "string", "description": "What it represents (request body, response payload, view-model, ...)" },
          "existingInterface": {
            "type": "string",
            "description": "If reusing, path::name of the existing interface from component-catalog.models."
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "optional": { "type": "boolean" },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "endpoints": {
      "type": "array",
      "description": "Backend API endpoints this feature consumes. Drives both real ApiService methods AND MockXxxService stub responses.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "method", "url", "purpose"],
        "properties": {
          "id": { "type": "string", "description": "kebab-case id, used as effect/action name root" },
          "method": { "type": "string", "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"] },
          "url": { "type": "string", "description": "URL pattern relative to API base, e.g. '/booking/cancel'" },
          "purpose": { "type": "string" },
          "requestModel": { "type": "string", "description": "Interface name from models[] (if applicable)" },
          "responseModel": { "type": "string" },
          "fixtureFile": {
            "type": "string",
            "description": "Captured-real-response file path (relative to projectRoot). If null, /aad-mock will fall back to AI-generated synthetic data from responseModel."
          }
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["featureKey", "shape"],
      "description": "NgRx feature-store specification.",
      "properties": {
        "featureKey": { "type": "string", "description": "Used as fromModule.featureKey + StoreModule.forFeature key" },
        "shape": {
          "type": "object",
          "description": "Initial state shape — fields with TS types.",
          "additionalProperties": true
        },
        "actions": {
          "type": "array",
          "description": "Suggested action names (createAction style). One per endpoint + UI command.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "purpose"],
            "properties": {
              "name": { "type": "string" },
              "purpose": { "type": "string" },
              "kind": { "type": "string", "enum": ["request", "success", "failure", "ui"] }
            }
          }
        },
        "selectors": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "purpose"],
            "properties": {
              "name": { "type": "string" },
              "purpose": { "type": "string" }
            }
          }
        },
        "effects": {
          "type": "array",
          "description": "One effect per request action.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "endpointId"],
            "properties": {
              "name": { "type": "string" },
              "endpointId": { "type": "string", "description": "References endpoints[].id" }
            }
          }
        }
      }
    },
    "i18n": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keys"],
      "description": "i18n keys this feature introduces. Format follows the project's i18nFlow.",
      "properties": {
        "keys": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "default"],
            "properties": {
              "key": { "type": "string", "description": "Dot-separated key, e.g. 'booking.cancel.title'" },
              "default": { "type": "string", "description": "English default value (or the working language baseline)" },
              "context": { "type": "string", "description": "Where it's used (screen + section)" }
            }
          }
        }
      }
    },
    "openQuestions": {
      "type": "array",
      "description": "Unresolved questions the planner couldn't answer from the spec.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string", "description": "q-NN" },
          "text": { "type": "string" },
          "blocks": {
            "type": "string",
            "enum": ["nothing", "codegen", "mock", "both"],
            "description": "What this question blocks if unanswered."
          }
        }
      }
    }
  }
}
