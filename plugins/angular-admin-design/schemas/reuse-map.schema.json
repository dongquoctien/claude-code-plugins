{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/dongquoctien/claude-code-plugins/main/plugins/angular-admin-design/schemas/reuse-map.schema.json",
  "title": "angular-admin-design reuse map",
  "description": "For every UI thing the plan needs, this file says: reuse-existing | create-new | needs-kendo | needs-new-shared. Generated by reuse-mapper agent from plan.json + component-catalog.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "feature", "createdAt", "summary", "items"],
  "properties": {
    "version": { "const": 1 },
    "feature": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reusedCount", "newCount"],
      "properties": {
        "reusedCount": { "type": "integer" },
        "newCount": { "type": "integer" },
        "kendoOnlyCount": { "type": "integer" },
        "needsNewSharedCount": { "type": "integer" }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["screenId", "sectionId", "requirement", "decision"],
        "properties": {
          "screenId": { "type": "string" },
          "sectionId": { "type": "string" },
          "requirement": {
            "type": "string",
            "description": "What the plan asks for (e.g. 'date range picker for check-in/out', 'data grid with sortable columns')."
          },
          "decision": {
            "type": "string",
            "enum": ["reuse-existing", "use-kendo", "create-feature-component", "needs-new-shared"]
          },
          "match": {
            "type": "object",
            "description": "Populated when decision = reuse-existing.",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "description": "Shared component class name from catalog (e.g. DatePickerComponent)" },
              "selector": { "type": "string" },
              "modulePath": { "type": "string" },
              "score": { "type": "number", "description": "0-1 confidence" },
              "rationale": { "type": "string" }
            }
          },
          "kendo": {
            "type": "object",
            "description": "Populated when decision = use-kendo.",
            "additionalProperties": false,
            "properties": {
              "module": { "type": "string", "description": "e.g. '@progress/kendo-angular-grid'" },
              "component": { "type": "string", "description": "e.g. 'kendo-grid'" },
              "rationale": { "type": "string" }
            }
          },
          "newComponent": {
            "type": "object",
            "description": "Populated when decision = create-feature-component or needs-new-shared.",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "description": "Suggested class name with Component suffix" },
              "location": {
                "type": "string",
                "enum": ["feature", "shared"],
                "description": "feature: lives in routes/<feature>/components. shared: new shared/modules/* — flagged for human review."
              },
              "rationale": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
